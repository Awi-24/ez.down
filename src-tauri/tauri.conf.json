{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ez.down",
  "mainBinaryName": "ezdown",
  "version": "1.0.0-beta.3",
  "identifier": "dev.ezdown.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ez.down",
        "width": 1100,
        "height": 760,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://asset.localhost data: https: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage"],
    "publisher": "Adrian Widmer",
    "copyright": "Copyright © 2026 Adrian Widmer",
    "category": "Productivity",
    "shortDescription": "Native WYSIWYG Markdown editor and reader.",
    "longDescription": "ez.down is a lightweight, open-source WYSIWYG Markdown editor and reader for Windows and Linux. Edit formatted Markdown without seeing the syntax, set it as your default .md app, and switch between beautiful built-in themes.",
    "homepage": "https://github.com/Awi-24/ez.down",
    "license": "MIT",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd"],
        "name": "Markdown Document",
        "description": "Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor"
      }
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2Q0I5RkFCNEEwNTU2MjQKUldRa1ZnVktxNS9MRnVtWWtlMGZrVTAybkNhWkJyME81WVBHN1ZRR0lSeGowalRkcVIwK2JEREgK",
      "endpoints": [
        "https://github.com/Awi-24/ez.down/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
